# Leave TELEGRAM_API_ID=0 and TELEGRAM_API_HASH=fill_later to use public read-only mode.
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=fill_later
TELEGRAM_SESSION_NAME=lead_funnel
TELEGRAM_CHANNELS=@freelance_dev_work

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=bot@example.com
SMTP_PASSWORD=change_me
MAIL_FROM=bot@example.com
MAIL_TO=you@example.com

IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=bot@example.com
IMAP_PASSWORD=change_me

# DeepSeek evaluates the scope and drafts a human-style Kwork proposal.
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat

# Optional OpenRouter vision. In smart mode it enriches screenshots and weak
# OCR for scanned files; fallback calls it only when local text is missing.
# Leave the model empty or set mode=off to disable cloud vision.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_VISION_MODEL=qwen/qwen3.7-plus
OPENROUTER_VISION_MODE=smart

DATABASE_PATH=data/leads.sqlite3
SCAN_INTERVAL_SECONDS=60
MAX_POSTS_PER_CHANNEL=30
MAX_SENDS_PER_RUN=5
KWORK_MAX_RESPONSES=5
KWORK_COOKIE=
KWORK_SOURCE=web
KWORK_PROJECTS_URL=https://kwork.ru/projects?c=11
KWORK_USE_BROWSER=1
KWORK_CDP_URL=http://127.0.0.1:9222
KWORK_BROWSER_PROFILE_DIR=
KWORK_AUTO_CHROME_COOKIES=1
KWORK_AUTO_REPLY=1
KWORK_LOGIN_EMAIL=
KWORK_LOGIN_PASSWORD=
LEAD_MIN_SCORE=60
LEAD_MAX_DAYS=7
LEAD_ACCEPT_DECISIONS=accept, maybe
LEAD_BLOCKED_KEYWORDS=битрикс, bitrix
# Optional extra static stop-words. Keep empty to let AI evaluate non-Bitrix stacks.
LEAD_HARD_REJECT_KEYWORDS=
LEAD_REQUIRED_KEYWORDS=
TESSERACT_CMD=D:\Tesseract-OCR\tesseract.exe
